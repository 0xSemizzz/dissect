# Telegram Bot Token (required)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Groq API Key (required)
# Get from https://console.groq.com/keys
GROQ_API_KEY=

# ─── Phase 2: Enrichment APIs (optional — bot works without them) ─────────────

# VirusTotal API Key (URL + hash reputation)
# Get from https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# MalwareBazaar API Key (optional — works without key)
# Get from https://bazaar.abuse.ch/api/#key
MALWAREBAZAAR_API_KEY=

# IPInfo API Key (IP geolocation + ASN)
# Get from https://ipinfo.io/account
IPINFO_API_KEY=

# ─── Phase 2+: Turso Database (optional — uses local SQLite by default) ───────

# Turso Database URL
# TURSO_DATABASE_URL=libsql://your-db.turso.io

# Turso Auth Token
# TURSO_AUTH_TOKEN=your-token-here
